# =========================================================================
# Escolha UM dos dois provedores de Qwen abaixo e preencha o .env real.
# (copie este arquivo:  cp .env.example .env)
# =========================================================================

# --- Opção A: DashScope (Qwen oficial da Alibaba, hosted) --------------
# Crie uma API key em: https://dashscope.console.aliyun.com/
QWEN_API_KEY=your_key_here
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# --- Opção B: Ollama local (grátis, offline, sem key) -----------------
# Instale o Ollama e rode:  ollama pull qwen2.5
# Depois comente o bloco acima e descomente estas 3 linhas:
# QWEN_API_KEY=ollama
# QWEN_BASE_URL=http://localhost:11434/v1
# QWEN_MODEL=qwen2.5
